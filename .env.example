# Laravel API base URL (no trailing slash). Used for auth + admin CRUD from the browser.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# AI Admin Agent (server-only — never expose to the browser)
LARAVEL_API_URL=http://localhost:8000/api
LARAVEL_API_TOKEN=

# Mock: USE_MOCK_AI=true | Groq: USE_MOCK_AI=false + AI_PROVIDER=groq
USE_MOCK_AI=false
AI_PROVIDER=groq

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Optional — only when AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
